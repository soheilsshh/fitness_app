server {
    listen 80;
    server_name example.com;

    root /var/www/fitness-app/dist;
    index index.html;

    location /_next/ {
        try_files $uri =404;
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}
