# Fitino frontend — static SPA export (frontend/dist)
#
# Common 403 on /admin or /leadfunnel:
#   - Old deploy left empty directories (admin/, leadfunnel/, ...) on disk
#   - try_files with "$uri/" finds the directory, finds no index → 403
# Fix: deploy a clean dist/ AND use try_files without "$uri/" (see location / below)

server {
    listen 80;
    server_name fitinoo.ir www.fitinoo.ir;

    root /var/www/fitness-app/dist;
    index index.html;

    # Public files (780027.txt, images, …)
    location = /780027.txt {
        try_files $uri =404;
    }

    location /_next/ {
        try_files $uri =404;
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # SPA fallback — do NOT use "$uri/" here (causes 403 when stale dirs exist)
    location / {
        try_files $uri /index.html;
    }
}

# After editing on the server:
#   sudo nginx -t && sudo systemctl reload nginx
#
# Clean redeploy (remove stale route folders from old static export):
#   rsync -av --delete frontend/dist/ /var/www/fitness-app/dist/
