# Fitino frontend — standard Next.js static export (frontend/dist)
# Each route folder contains index.html (e.g. dist/admin/index.html).

server {
    listen 80;
    server_name fitinoo.ir www.fitinoo.ir;

    root /var/www/fitinoo/frontend/dist;
    index index.html;

    location /_next/ {
        try_files $uri =404;
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # Static files: never fall through to index.html (200 + HTML breaks <img>).
    location ~* \.(?:png|jpe?g|gif|webp|svg|ico|mp4|webm|woff2?|ttf|css|js|map)$ {
        try_files $uri =404;
        expires 7d;
        add_header Cache-Control "public";
    }

    location / {
        try_files $uri $uri/ =404;
    }
}

# Deploy:
#   cd frontend && npm run build
#   rsync -av --delete dist/ root@fitinoo.ir:/var/www/fitinoo/frontend/dist/
#
# Reload:
#   sudo nginx -t && sudo systemctl reload nginx
