# Fitino backend — production template
# Copy to config.yaml (gitignored) and fill secrets:
#   cp config.yaml.example config.yaml
#
# No .env required for production.
# Priority if both exist: environment / .env  >  config.yaml  >  built-in defaults

app:
  env: production

server:
  host: "0.0.0.0"
  port: 8088

cors:
  allowed_origins:
    - https://fitinoo.ir
    - https://www.fitinoo.ir
    - http://fitinoo.ir
    - http://www.fitinoo.ir
  allow_localhost: false
  allow_credentials: false

database:
  host: localhost
  port: 3306
  user: fitino
  password: "CHANGE_ME"
  name: fitness_db

jwt:
  secret: CHANGE_ME_TO_A_LONG_RANDOM_SECRET
  access_token_duration_minutes: 15
  refresh_token_duration_days: 7

upload:
  dir: uploads

seed:
  # Full JSON fixtures (orders/programs/…) — blocked when app.env=production
  dev_data: false
  # Lightweight mock coaches/students for demos/videos (idempotent)
  demo_data: true
  # On API startup: seed exercises + foods + crul templates (skip if tables already filled)
  catalogs: true
  # Re-import catalogs even when rows already exist
  catalogs_force: false

funnel:
  # Funnel 1 — علی رشیدآبادی only (/ali-rashidabadi).
  # Funnel 2 would be another dedicated funnel later.
  # Pricing comes from this coach's ServicePlan rows in the DB.
  coach_slug: "ali-rashidabadi"

sms:
  # Kavenegar Verify Lookup — https://kavenegar.com
  api_key: "YOUR_KAVENEGAR_API_KEY"
  originator: ""
  otp_pattern_code: "fittino-otp"
  # Verify Lookup template for "program ready" SMS (token = first name). Create in Kavenegar panel.
  program_ready_pattern_code: "fittino-program"
  otp_ttl_minutes: 10
  otp_resend_cooldown_seconds: 60

payments:
  zarinpal:
    # Required for live / funnel checkout — read by backend on every pay request.
    merchant_id: "YOUR-ZARINPAL-MERCHANT-UUID"
    sandbox: false
    callback_base_url: "https://api.fitinoo.ir"
    web_result_url: "https://fitinoo.ir/payment/result"
    mobile_deep_link_scheme: "fitinoo"

openai:
  # GapGPT or OpenAI-compatible Chat Completions
  api_key: "YOUR_OPENAI_OR_GAPGPT_API_KEY"
  model: "gemini-3.1-flash-lite"
  base_url: "https://api.gapgpt.app/v1"
