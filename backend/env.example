# Optional legacy overrides — prefer config.yaml in the backend directory.
# Copy config.yaml.example to config.yaml and edit there first:
#   cp config.yaml.example config.yaml
#
# Environment variables still override config.yaml when both are set.

PORT=8088
FRONTEND_ORIGIN=https://fitinoo.ir,https://www.fitinoo.ir
APP_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=fitness_db

JWT_SECRET=change-me-in-production
ACCESS_TOKEN_DURATION_MINUTES=15
REFRESH_TOKEN_DURATION_DAYS=7

UPLOAD_DIR=uploads

# Load development/UI test fixtures on app startup (blocked when APP_ENV=production).
# Prefer: go run ./cmd/seed -dev
SEED_DEV_DATA=false
