# Optional legacy overrides — prefer config.yaml in the backend directory.
# Copy config.yaml.example to config.yaml and edit there first:
#   cp config.yaml.example config.yaml
#
# Environment variables still override config.yaml when both are set.

PORT=8088
FRONTEND_ORIGIN=https://fitinoo.ir,https://www.fitinoo.ir
APP_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=fitness_db

JWT_SECRET=change-me-in-production
ACCESS_TOKEN_DURATION_MINUTES=15
REFRESH_TOKEN_DURATION_DAYS=7

UPLOAD_DIR=uploads

# Load development/UI test fixtures on app startup (blocked when APP_ENV=production).
# Prefer: go run ./cmd/seed -dev
SEED_DEV_DATA=false

# Kavenegar SMS (Verify Lookup). Leave empty in dev to log OTP codes only.
SMS_API_KEY=
SMS_ORIGINATOR=
SMS_OTP_PATTERN_CODE=fittino-otp
SMS_OTP_TTL_MINUTES=10
SMS_OTP_RESEND_COOLDOWN_SECONDS=60

# ZarinPal payment gateway
ZARINPAL_MERCHANT_ID=
ZARINPAL_SANDBOX=true
ZARINPAL_CALLBACK_BASE_URL=https://api.fitinoo.ir
ZARINPAL_WEB_RESULT_URL=https://fitinoo.ir/payment/result
ZARINPAL_MOBILE_DEEP_LINK_SCHEME=fitinoo
