# OPTIONAL — only for local development overrides.
# Production runs without this file and uses config.yaml.
#
# If this file exists next to the binary / cwd, it OVERRIDES config.yaml.
# To force production from config.yaml: delete or rename this file.
#
# Example local-only overrides:
#   APP_ENV=development
#   DB_USER=root
#   DB_PASSWORD=
#   SMS_API_KEY=
#   OPENAI_API_KEY=
#   ZARINPAL_SANDBOX=true

APP_ENV=development
PORT=8088

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=fitness_db

JWT_SECRET=dev-secret-local-only

SMS_API_KEY=
OPENAI_API_KEY=
ZARINPAL_SANDBOX=true
