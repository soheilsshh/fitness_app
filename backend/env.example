PORT=8080
FRONTEND_ORIGIN=http://localhost:3000
APP_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=fitness_db

JWT_SECRET=change-me-in-production
